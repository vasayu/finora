# ── Frontend .dockerignore ─────────────────────
# Keep build context small & fast

node_modules
.next
out
.git
.gitignore
.DS_Store
*.log
npm-debug.log*

# Server code (not needed in frontend image)
server/

# Env files (injected at runtime via docker-compose)
.env*
!.env.example

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore

# Misc
README.md
docs/
*.tsbuildinfo
