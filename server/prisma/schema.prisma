// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  firstName      String
  lastName       String
  role           Role           @default(EMPLOYEE)
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  documents      Document[]
  transactions   Transaction[]
  auditTrails    AuditTrail[]
  watchlist      Watchlist[]

  // Role-specific profiles (only one will be populated based on role)
  employeeProfile   EmployeeProfile?
  accountantProfile AccountantProfile?
  cfoProfile        CFOProfile?
  managerProfile    ManagerProfile?
  investorProfile   InvestorProfile?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Organization {
  id           String         @id @default(uuid())
  name         String
  inviteCode   String         @unique
  ownerId      String
  users        User[]
  documents    Document[]
  transactions Transaction[]
  orgWatchlist  OrgWatchlist[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

enum Role {
  EMPLOYEE
  ACCOUNTANT
  CFO
  MANAGER
  INVESTOR
}

// ─── Role-Specific Profiles ───────────────────────────────────────

model EmployeeProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   String?
  position     String?
  salary       Float?
  joiningDate  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AccountantProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  certifications  String[] @default([])
  specialization  String?
  managedAccounts Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CFOProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearsExperience Int      @default(0)
  boardMember     Boolean  @default(false)
  strategicNotes  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ManagerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      String?
  teamSize        Int      @default(0)
  budgetAuthority Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InvestorProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  investmentFirm  String?
  portfolioValue  Float    @default(0)
  investmentType  String?  // e.g., "Equity", "Debt", "Convertible"
  sector          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Core Models ──────────────────────────────────────────────────

model Document {
  id             String       @id @default(uuid())
  fileName       String
  fileUrl        String
  fileType       String
  status         DocStatus    @default(PENDING)
  extractedData  Json?
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum DocStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transaction {
  id             String       @id @default(uuid())
  amount         Float
  currency       String       @default("USD")
  type           TxType
  category       String
  date           DateTime     @default(now())
  description    String?
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum TxType {
  INCOME
  EXPENSE
}

model FinancialRecord {
  id             String       @id @default(uuid())
  organizationId String
  month          Int
  year           Int
  totalIncome    Float        @default(0)
  totalExpense   Float        @default(0)
  netProfit      Float        @default(0)
  assets         Float        @default(0)
  liabilities    Float        @default(0)
  equity         Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, month, year])
}

model Alert {
  id        String       @id @default(uuid())
  type      String       // e.g., "LOW_BALANCE", "ANOMALY"
  message   String
  isRead    Boolean      @default(false)
  userId    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AuditTrail {
  id        String       @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  details   Json?
  createdAt DateTime     @default(now())
}

// ─── Watchlist Models ─────────────────────────────────────────────

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  addedAt   DateTime @default(now())

  @@unique([userId, symbol])
}

model OrgWatchlist {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  symbol         String
  name           String
  addedByUserId  String
  addedAt        DateTime     @default(now())

  @@unique([organizationId, symbol])
}
